# Copy this to .env and fill in your keys
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...

# SEC EDGAR requires a User-Agent string (your name + email, free, no key needed)
EDGAR_USER_AGENT="YourFundName research@yourfund.com"

# Model config
ANALYSIS_MODEL=claude-opus-4-6        # for final report generation
FAST_MODEL=claude-sonnet-4-6          # for intermediate steps / tool calls
